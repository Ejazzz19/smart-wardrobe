# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - leave blank to use local SQLite.
# For production (Neon/Supabase Postgres), set the full connection URL:
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=

# CORS - comma separated origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Cloudinary (image storage) - get these from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
